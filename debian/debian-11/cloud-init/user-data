#cloud-config
autoinstall:
  version: 1
  locale: en_US
  keyboard:
    layout: en
    variant: us
  storage:
    layout:
      name: lvm
  identity:
    hostname: ubuntu
    username: ubuntu
    # Replace with a real SHA-512 hash before use:
    # password: "$6$rounds=4096$..."
    lock_passwd: false
  ssh:
    allow-pw: true
    install-server: yes
    # Replace with your SSH public keys before use:
    # authorized-keys:
    #   - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... your_key
  user-data:
    disable_root: true
  packages:
    - qemu-guest-agent
  late-commands:
    - echo 'ubuntu ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/ubuntu
