# Copy this file to debian.auto.pkrvars.hcl and fill in real values.
# Files matching *.auto.pkrvars.hcl are gitignored to avoid leaking secrets.

proxmox_node      = "homelab"
http_bind_address = "0.0.0.0"
http_host         = "YOUR_BUILD_HOST_IP"

ssh_username   = "yimeng"
ssh_password   = "CHANGE_ME"
ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... your_key"

iso_file = "local:iso/debian-13.5.0-amd64-netinst.iso"
